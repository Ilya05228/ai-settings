#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

usage() {
  cat <<'EOF'
ai-settings: команды

Команды:
  ./commands help
  ./commands --help
  ./commands -h
  ./commands sync-all
  ./commands sync-plugin <name>
  ./commands make-docs
  ./commands new-plugin <name>
  ./commands install --dest <path> --plugins a,b,c
  ./commands install --dest <path> --plugins a,b,c --force
  ./commands install --dest <path> --all
  ./commands install --dest <path> --all --force

Примечания:
  - метаданные плагина: plugins/<name>/plugin.json
  - описание плагина: plugins/<name>/description.md (ручной файл)
  - install не запускает sync-all; перед установкой выполни ./commands sync-all,
    если нужны свежие копии внешних плагинов в plugins/<name>/
  - при install каждый скилл — папка с SKILL.md; имя папки = <плагин>-<name из YAML
    или имя каталога>. В SKILL.md в поле name записывается то же значение.
  - агенты: файл <плагин>-<name из YAML или stem>.md, поле name в шапке совпадает
    с именем файла (без .md).
  - MCP: опциональный plugins/<name>/mcp.json — объект mcpServers (один или несколько
    серверов на плагин, если нужно сгруппировать).
    По умолчанию в <dest>/mcp.json добавляются только новые имена серверов;
    существующие папки скиллов/файлы агентов/ключи MCP не перезаписываются —
    при любом совпадении install завершается с ошибкой до любых изменений (двухфазно).
    С флагом --force проверки на уже существующие skill/agent/MCP-ключи отключаются:
    каталоги скиллов удаляются и копируются заново, файлы агентов перезаписываются,
    конфиги MCP с совпадающими именами серверов перезаписываются значениями из устанавливаемых плагинов.
  - --all: ставит все каталоги из plugins/ с plugin.json, кроме _base.
EOF
}

die() { echo "$*" >&2; exit 1; }

cmd="${1:-}"
shift || true

sync_all() {
  python3 - <<'PY'
import json, subprocess
from pathlib import Path

plugins_dir = Path("plugins").resolve()

def load_cfg(p: Path):
  try:
    return json.loads((p / "plugin.json").read_text(encoding="utf-8"))
  except Exception:
    return None

for p in sorted(plugins_dir.iterdir()):
  if not p.is_dir():
    continue
  cfg = load_cfg(p)
  if not cfg or not cfg.get("external"):
    continue
  sync_cfg = cfg.get("sync") or {}
  if not sync_cfg.get("enabled", False):
    continue
  script = sync_cfg.get("script") or "sync.sh"
  script_path = p / script
  if not script_path.exists():
    print(f"  ! {p.name}: missing {script}")
    continue
  print(f"== {p.name} ==")
  try:
    subprocess.check_call(["bash", str(script_path)])
  except subprocess.CalledProcessError as e:
    print(f"  ! {p.name}: sync failed (exit {e.returncode})")
    # Continue syncing other plugins instead of failing sync-all.
    continue
PY
}

sync_one() {
  local name="$1"
  local dir="$ROOT/plugins/$name"
  [[ -d "$dir" ]] || die "No such plugin: $name"
  [[ -f "$dir/plugin.json" ]] || die "Missing plugin.json for: $name"
  python3 - "$dir" <<'PY'
import json, subprocess, sys
from pathlib import Path
p = Path(sys.argv[1]).resolve()
cfg = json.loads((p/"plugin.json").read_text(encoding="utf-8"))
if not cfg.get("external"):
  print("skip: not external")
  raise SystemExit(0)
sync_cfg = cfg.get("sync") or {}
if not sync_cfg.get("enabled", False):
  print("skip: sync.disabled")
  raise SystemExit(0)
script = sync_cfg.get("script") or "sync.sh"
script_path = p / script
subprocess.check_call(["bash", str(script_path)])
PY
}

generate_docs() {
  mkdir -p "$ROOT/docs"
  python3 - >"$ROOT/docs/PLUGINS.md" <<'PY'
import json
from pathlib import Path

plugins = []
for p in sorted(Path("plugins").iterdir()):
  if not p.is_dir():
    continue
  cfg_path = p/"plugin.json"
  if not cfg_path.exists():
    continue
  cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
  src = cfg.get("source") if cfg.get("external") else None
  plugins.append({
    "name": cfg.get("name", p.name),
    "description": cfg.get("description","").strip(),
    "external": bool(cfg.get("external", False)),
    "source": (src.get("url") if isinstance(src, dict) else "") if src else "",
  })

print("# Плагины")
print()
print("| плагин | внешний | источник | описание |")
print("|--------|---------|----------|----------|")
for x in plugins:
  src = x["source"]
  if src:
    src = f"`{src}`"
  print(f"| `{x['name']}` | `{str(x['external']).lower()}` | {src} | {x['description']} |")
PY
  echo "wrote docs/PLUGINS.md"
}

new_plugin() {
  local name="$1"
  [[ "$name" =~ ^[a-z0-9][a-z0-9._-]*$ ]] || die "Bad name: $name"
  local dst="$ROOT/plugins/$name"
  [[ -e "$dst" ]] && die "Already exists: plugins/$name"
  cp -a "$ROOT/plugins/_base" "$dst"
  python3 - "$dst/plugin.json" "$name" <<'PY'
import json, sys
path = sys.argv[1]
name = sys.argv[2]
cfg = json.load(open(path, encoding="utf-8"))
cfg["name"] = name
cfg["description"] = f"{name} plugin."
cfg["external"] = False
cfg.pop("source", None)
json.dump(cfg, open(path,"w",encoding="utf-8"), ensure_ascii=False, indent=2)
open(path,"a",encoding="utf-8").write("\n")
PY
  chmod +x "$dst/sync.sh" || true
  echo "created plugins/$name"
}

install_to() {
  local dest=""
  local plugins=""
  local use_all=0
  local force=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dest) dest="${2:-}"; shift 2;;
      --plugins) plugins="${2:-}"; shift 2;;
      --all) use_all=1; shift;;
      --force) force=1; shift;;
      *) die "Unknown arg: $1";;
    esac
  done
  [[ -n "$dest" ]] || die "install requires --dest"
  if [[ "$use_all" -eq 1 ]]; then
    [[ -z "$plugins" ]] || die "install: use either --all or --plugins, not both"
    plugins=""
    local d name
    for d in "$ROOT/plugins"/*/; do
      [[ -d "$d" ]] || continue
      name="$(basename "$d")"
      [[ "$name" == "_base" ]] && continue
      [[ -f "${d}plugin.json" ]] || continue
      plugins="${plugins:+$plugins,}$name"
    done
    [[ -n "$plugins" ]] || die "install --all: no plugins found (need plugins/*/plugin.json, not _base)"
  else
    if [[ -n "$plugins" ]] && [[ "${plugins,,}" == "all" ]]; then
      die "install: use --all to install every plugin (not --plugins all)"
    fi
    [[ -n "$plugins" ]] || die "install requires --plugins <list> or --all"
  fi
  # стабильный порядок (имена плагинов)
  plugins="$(printf '%s' "$plugins" | tr ',' '\n' | sed '/^$/d' | sort -u | paste -sd, -)"

  mkdir -p "$dest/skills" "$dest/agents"

  python3 - "$ROOT" "$dest" "$plugins" "$force" <<'PY'
import json
import re
import shutil
import sys
from pathlib import Path

ROOT = Path(sys.argv[1]).resolve()
dest_root = Path(sys.argv[2]).resolve()
plugins_csv = sys.argv[3]
force = sys.argv[4] == "1"

FM_RE = re.compile(r"\A---\n([\s\S]*?)\n---\n([\s\S]*)\Z")


def slugify(s: str) -> str:
    s = (s or "").strip().lower()
    s = re.sub(r"[^a-z0-9_.-]+", "-", s)
    s = re.sub(r"-+", "-", s).strip("-")
    return s or "item"


def split_fm(text: str):
    m = FM_RE.match(text)
    if m:
        return m.group(1), m.group(2)
    return None, text


def extract_name_from_block(block):
    if not block:
        return None
    m = re.search(r"^name:\s*(.+)$", block, re.M)
    if not m:
        return None
    return m.group(1).strip().strip("\"'")


def merge_frontmatter(text: str, new_name: str) -> str:
    block, body = split_fm(text)
    if block is None:
        return f"---\nname: {new_name}\n---\n\n" + text
    nb = block
    if re.search(r"^name:\s*", nb, re.M):
        nb = re.sub(r"^name:\s*[^\n]*$", f"name: {new_name}", nb, count=1, flags=re.M)
    else:
        nb = f"name: {new_name}\n" + nb
    return f"---\n{nb}\n---\n{body}"


def load_plugin_mcp_servers(base: Path) -> dict:
    p = base / "mcp.json"
    if not p.is_file():
        return {}
    try:
        data = json.loads(p.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise SystemExit(f"Invalid JSON: {p}: {e}") from e
    servers = data.get("mcpServers")
    if servers is None:
        return {}
    if not isinstance(servers, dict):
        raise SystemExit(f"{p}: mcpServers must be a JSON object")
    return servers


def read_dest_mcp(dest_root: Path) -> tuple[dict, dict]:
    p = dest_root / "mcp.json"
    if not p.is_file():
        return {}, {}
    try:
        data = json.loads(p.read_text(encoding="utf-8"))
    except json.JSONDecodeError as e:
        raise SystemExit(f"Invalid JSON in existing {p}: {e}") from e
    if not isinstance(data, dict):
        raise SystemExit(f"{p}: root must be a JSON object")
    servers = data.get("mcpServers")
    if servers is None:
        servers = {}
    if not isinstance(servers, dict):
        raise SystemExit(f"{p}: mcpServers must be a JSON object")
    return data, servers


def plan_skill_targets(plugin: str, base: Path) -> list[tuple[str, Path]]:
    base_skills = base / "skills"
    if not base_skills.is_dir():
        return []
    seen_roots: dict[str, Path] = {}
    out: list[tuple[str, Path]] = []
    for skill_md in sorted(base_skills.rglob("SKILL.md")):
        root = skill_md.parent
        raw = skill_md.read_text(encoding="utf-8")
        block, _ = split_fm(raw)
        author_raw = extract_name_from_block(block)
        author_slug = slugify(author_raw or root.name)
        dest_name = f"{plugin}-{author_slug}"
        if dest_name in seen_roots and seen_roots[dest_name] != root:
            extra = slugify(root.name)
            dest_name = (
                f"{plugin}-{author_slug}-{extra}"
                if extra != author_slug
                else f"{plugin}-{author_slug}-{len(seen_roots)}"
            )
        seen_roots[dest_name] = root
        out.append((dest_name, root))
    return out


def plan_agent_targets(plugin: str, base: Path) -> list[tuple[str, Path]]:
    base_agents = base / "agents"
    if not base_agents.is_dir():
        return []
    used_files: dict[str, Path] = {}
    out: list[tuple[str, Path]] = []
    for md in sorted(base_agents.rglob("*.md")):
        raw = md.read_text(encoding="utf-8")
        block, _ = split_fm(raw)
        author_raw = extract_name_from_block(block)
        author_slug = slugify(author_raw or md.stem)
        dest_bn = f"{plugin}-{author_slug}.md"
        if dest_bn in used_files and used_files[dest_bn] != md:
            dest_bn = f"{plugin}-{author_slug}-{slugify(md.parent.name)}.md"
        used_files[dest_bn] = md
        out.append((dest_bn, md))
    return out


def collect_conflicts(dest_root: Path, plugins: list[str], force: bool) -> list[str]:
    conflicts: list[str] = []
    dest_skills = dest_root / "skills"
    dest_agents = dest_root / "agents"
    _, existing_mcp = read_dest_mcp(dest_root)
    batch_mcp_owner: dict[str, str] = {}
    all_skill_names: list[tuple[str, str]] = []
    all_agent_names: list[tuple[str, str]] = []

    for plugin in plugins:
        base = ROOT / "plugins" / plugin
        for dest_name, _root in plan_skill_targets(plugin, base):
            all_skill_names.append((plugin, dest_name))
        for dest_bn, _md in plan_agent_targets(plugin, base):
            all_agent_names.append((plugin, dest_bn))
        mcp = load_plugin_mcp_servers(base)
        for key in mcp:
            if key in batch_mcp_owner and batch_mcp_owner[key] != plugin:
                conflicts.append(
                    f"MCP server name conflict in this install: {key!r} "
                    f"(plugins {batch_mcp_owner[key]!r} and {plugin!r})"
                )
            elif key not in batch_mcp_owner:
                batch_mcp_owner[key] = plugin

    seen_s: set[str] = set()
    for plugin, name in all_skill_names:
        if name in seen_s:
            conflicts.append(f"internal: duplicate skill target {name!r} (plugin {plugin!r})")
        seen_s.add(name)
    seen_a: set[str] = set()
    for plugin, bn in all_agent_names:
        if bn in seen_a:
            conflicts.append(f"internal: duplicate agent target {bn!r} (plugin {plugin!r})")
        seen_a.add(bn)

    if not force:
        for plugin, dest_name in all_skill_names:
            p = dest_skills / dest_name
            if p.exists():
                rel = p.relative_to(dest_root)
                conflicts.append(
                    f"skill folder already exists: {rel} (would install from plugin {plugin!r})"
                )

        for plugin, dest_bn in all_agent_names:
            p = dest_agents / dest_bn
            if p.exists():
                rel = p.relative_to(dest_root)
                conflicts.append(
                    f"agent file already exists: {rel} (would install from plugin {plugin!r})"
                )

        for key, owner in batch_mcp_owner.items():
            if key in existing_mcp:
                conflicts.append(
                    f"MCP server {key!r} already in mcp.json (would add from plugin {owner!r})"
                )

    return conflicts


def apply_install(dest_root: Path, plugins: list[str], force: bool) -> None:
    dest_skills = dest_root / "skills"
    dest_agents = dest_root / "agents"
    full_doc, existing_servers = read_dest_mcp(dest_root)
    new_servers = dict(existing_servers)
    mcp_touched = False

    for plugin in plugins:
        base = ROOT / "plugins" / plugin
        print(f"== {plugin} ==")
        for dest_name, root in plan_skill_targets(plugin, base):
            dd = dest_skills / dest_name
            if dd.exists():
                if force:
                    shutil.rmtree(dd)
                else:
                    raise RuntimeError(f"unexpected existing skill dir: {dd}")
            shutil.copytree(root, dd, symlinks=True)
            out = dd / "SKILL.md"
            out.write_text(merge_frontmatter(out.read_text(encoding="utf-8"), dest_name), encoding="utf-8")
            print(f"  + skill {dest_name}")

        for dest_bn, md in plan_agent_targets(plugin, base):
            out = dest_agents / dest_bn
            shutil.copy2(md, out)
            final_name = out.stem
            out.write_text(merge_frontmatter(out.read_text(encoding="utf-8"), final_name), encoding="utf-8")
            print(f"  + agent {dest_bn}")

        frag = load_plugin_mcp_servers(base)
        for k, v in frag.items():
            new_servers[k] = v
            mcp_touched = True
            print(f"  + mcp server {k}")

    if mcp_touched:
        full_out = dict(full_doc)
        full_out["mcpServers"] = new_servers
        mcp_path = dest_root / "mcp.json"
        mcp_path.write_text(
            json.dumps(full_out, ensure_ascii=False, indent=2) + "\n",
            encoding="utf-8",
        )
        print(f"  wrote {mcp_path.name}")


plugin_list = [t.strip() for t in plugins_csv.split(",") if t.strip()]
for plugin in plugin_list:
    base = ROOT / "plugins" / plugin
    if not base.is_dir():
        print(f"No such plugin dir: {plugin}", file=sys.stderr)
        sys.exit(1)

conflicts = collect_conflicts(dest_root, plugin_list, force)
if conflicts:
    print("Install aborted: conflicts (nothing was changed):", file=sys.stderr)
    for c in conflicts:
        print(f"  - {c}", file=sys.stderr)
    sys.exit(1)

apply_install(dest_root, plugin_list, force)
PY
}

case "$cmd" in
  help)
    usage; exit 0;;
  sync-all)
    sync_all
    exit 0;;
  sync-plugin)
    sync_one "${1:-}"
    exit 0;;
  make-docs)
    generate_docs
    exit 0;;
  new-plugin)
    new_plugin "${1:-}"
    exit 0;;
  install)
    install_to "$@"
    exit 0;;
  ""|-h|--help)
    usage; exit 0;;
  *)
    usage; exit 2;;
esac

