#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

MP="$ROOT/marketplace.json"
if [[ ! -f "$MP" ]]; then
  echo "marketplace.json not found"
  exit 1
fi

echo "== purge external =="

# We intentionally avoid jq as a hard dependency.
# Parse JSON very simply: extract strings inside "externalPaths": [ ... ].
PATHS="$(
  python3 - <<'PY'
import json, pathlib
p = pathlib.Path("marketplace.json")
mp = json.loads(p.read_text(encoding="utf-8"))
for x in mp.get("externalPaths", []):
    if not isinstance(x, str) or not x:
        continue
    print(x)
PY
)"

while IFS= read -r rel; do
  [[ -z "$rel" ]] && continue
  target="$ROOT/$rel"
  if [[ -e "$target" ]]; then
    rm -rf "$target"
    echo "  - $rel"
  fi
done <<<"$PATHS"

echo "Готово."

