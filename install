#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

usage() {
  cat <<'EOF'
Usage:
  bash ./install --dest <path> --plugins <comma-separated>

Example (Cursor-style folder):
  bash ./install --dest /path/to/project/.cursor --plugins pdf,docx,superpowers

What it does:
  1) runs ./sync (which purges+syncs external content)
  2) copies selected plugins into <dest> with flattened names:
     skills: <plugin>-<skill>
     agents: <plugin>-<agent>

Notes:
  - creates <dest>/skills and <dest>/agents
  - does not delete existing dest content
EOF
}

DEST=""
PLUGINS=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dest)
      DEST="${2:-}"; shift 2;;
    --plugins)
      PLUGINS="${2:-}"; shift 2;;
    -h|--help)
      usage; exit 0;;
    *)
      echo "Unknown arg: $1"
      usage
      exit 2;;
  esac
done

if [[ -z "$DEST" || -z "$PLUGINS" ]]; then
  usage
  exit 2
fi

mkdir -p "$DEST/skills" "$DEST/agents"

echo "== sync =="
bash "$ROOT/sync"

echo "== install -> $DEST =="

IFS=',' read -r -a PLUGIN_LIST <<<"$PLUGINS"

copy_dir() {
  local src="$1"
  local dst="$2"
  rm -rf "$dst"
  mkdir -p "$(dirname "$dst")"
  cp -a "$src" "$dst"
}

for plugin in "${PLUGIN_LIST[@]}"; do
  plugin="${plugin// /}"
  [[ -z "$plugin" ]] && continue
  base="$ROOT/plugins/$plugin"
  if [[ ! -d "$base" ]]; then
    echo "  ! skip $plugin: no such plugin dir"
    continue
  fi

  # skills: copy each subdir under plugins/<plugin>/skills/<skillname> -> dest/skills/<plugin>-<skillname>
  if [[ -d "$base/skills" ]]; then
    for s in "$base/skills"/*; do
      [[ -d "$s" ]] || continue
      skill="$(basename "$s")"
      copy_dir "$s" "$DEST/skills/${plugin}-${skill}"
      echo "  + skill ${plugin}-${skill}"
    done
  fi

  # agents: copy md files under plugins/<plugin>/agents (and nested plugin bundles) to dest/agents/<plugin>-<filename>
  if [[ -d "$base/agents" ]]; then
    while IFS= read -r -d '' f; do
      bn="$(basename "$f")"
      copy_dir "$f" "$DEST/agents/${plugin}-${bn}"
      echo "  + agent ${plugin}-${bn}"
    done < <(find "$base/agents" -type f -name "*.md" -print0)
  fi
done

echo "Готово."

